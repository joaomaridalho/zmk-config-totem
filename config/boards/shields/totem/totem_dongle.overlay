#include "totem.dtsi"

/ {
    chosen {
        zmk,kscan = &mock_kscan;
        /delete-property/ zephyr,console;
        /delete-property/ zephyr,shell-uart;
    };

    mock_kscan: kscan_1 {
        compatible = "zmk,kscan-mock";
        columns = <0>;
        rows = <0>;
        events = <0>;
    };
};

&default_layout {
    kscan = <&mock_kscan>;
};
